    openPasswordChangePopup: function() {
        console.log("HELLO"); // 함수가 실행될 때 찍히도록 내부에 삽입
        // ... 기존 함수 로직 ...
    }, // 앞뒤 함수 사이에 쉼표가 있는지 확인!
